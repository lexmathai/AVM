---
const title = "Alexander Mathai · Founder, Texas Movement International LLC";
const description =
  "Alexander Mathai is the founder of Texas Movement International LLC. He builds systems for performance, media, consulting, IP defense, AI workflows, and strategic operations for founders and teams.";
const url = "https://alexandermathai.com";

const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Alexander Mathai",
  url,
  jobTitle: "Founder",
  worksFor: {
    "@type": "Organization",
    name: "Texas Movement International LLC",
    url: "https://texasmovement.com",
  },
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "BS in Civil Engineering",
  },
  sameAs: [
    "https://www.linkedin.com/in/alexandermathai",
    "https://www.instagram.com/alexanderofnazareth/",
    "https://www.tiktok.com/@AlexanderVMathai",
    "https://texasmovement.com",
  ],
  description:
    "Founder of Texas Movement International LLC. Builds systems for performance, media, consulting, IP defense, AI workflows, and strategic operations.",
};

const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Texas Movement International LLC",
  url: "https://texasmovement.com",
  description:
    "A systems company focused on footwear, performance, media, consulting, IP defense, and strategic operations.",
  sameAs: [
    "https://www.linkedin.com/company/texas-movement-consulting",
  ],
  contactPoint: [
    {
      "@type": "ContactPoint",
      contactType: "General Inquiries",
      email: "movementconsultant@gmail.com",
    },
  ],
};

const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Alexander Mathai",
  url,
  description:
    "Founder page for Alexander Mathai, operator behind Texas Movement International LLC.",
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Who is Alexander Mathai?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "Alexander Mathai is the founder of Texas Movement International LLC and the operator behind its consulting, media, performance, IP defense, and systems work.",
      },
    },
    {
      "@type": "Question",
      name: "What does Alexander Mathai do?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "He builds systems for founders and teams who need help with strategy, AI workflows, media operations, IP defense, and complex execution problems.",
      },
    },
    {
      "@type": "Question",
      name: "What is Texas Movement International LLC?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "Texas Movement International LLC is the company Alexander founded to organize footwear, performance, media, consulting, IP defense, and strategic operations under one operating structure.",
      },
    },
    {
      "@type": "Question",
      name: "Who is this page for?",
      acceptedAnswer: {
        "@type": "Answer",
        text:
          "This page is for founders, operators, legal teams, promoters, and brands that need a clear profile of the person behind Texas Movement and a direct path into the ecosystem.",
      },
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="profile" />
    <meta property="og:url" content={url} />
    <meta property="og:image" content="/og-alexander-mathai.png" />
    <meta property="og:site_name" content="Alexander Mathai" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-alexander-mathai.png" />

    <script type="application/ld+json">{JSON.stringify(personJsonLd)}</script>
    <script type="application/ld+json">{JSON.stringify(organizationJsonLd)}</script>
    <script type="application/ld+json">{JSON.stringify(websiteJsonLd)}</script>
    <script type="application/ld+json">{JSON.stringify(faqJsonLd)}</script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="true" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <main class="page">
      <header class="topbar">
        <div class="brand">
          <div class="brand-mark">A</div>
          <div class="brand-copy">
            <div class="brand-name">Alexander Mathai</div>
            <div class="brand-subtitle">Founder, Texas Movement International LLC</div>
          </div>
        </div>
        <nav class="nav">
          <a href="#overview">Overview</a>
          <a href="#work">Work</a>
          <a href="#keynote">Keynote</a>
          <a href="#tm-links">Texas Movement</a>
          <a href="#socials">Socials</a>
          <a href="#faq">FAQ</a>
          <a href="#contact">Contact</a>
        </nav>
      </header>

      <section id="overview" class="hero">
        <div class="hero-copy">
          <p class="eyebrow">FOUNDERSHIP · SYSTEMS · EXECUTION</p>
          <h1>Alexander Mathai builds systems for performance, media, consulting, IP defense, and strategic operations.</h1>
          <p class="lead">
            Alexander Mathai is the founder of Texas Movement International LLC. He works on complex workflows, founder
            operations, AI-assisted systems, platform-side IP defense, and strategic problem-solving for operators,
            legal teams, promoters, and brands.
          </p>
          <p class="supporting">
            This page is the personal authority layer. Texas Movement is the company layer. Together, they show the person
            behind the system and the system behind the company.
          </p>
          <div class="cta-row">
            <a class="button primary" href="https://texasmovement.com/" target="_blank" rel="noreferrer">
              Visit Texas Movement
            </a>
            <a class="button secondary" href="#contact">
              Contact Alexander
            </a>
          </div>
        </div>

        <aside class="hero-card">
          <div class="portrait-wrap">
            <img
              src="/AVM-Blue-turtleneck-standing-arm-cross.jpg"
              alt="Alexander Mathai portrait"
              class="portrait"
            />
          </div>
          <div class="hero-card-body">
            <p class="hero-card-title">What I do</p>
            <p>
              I help serious people organize messy problems into workable systems. That includes consulting strategy,
              AI workflows, media operations, IP defense through Texas Movement Distribution, performance systems, and
              cross-functional execution support.
            </p>
          </div>
        </aside>
      </section>

      <section id="work" class="section">
        <h2>Core focus areas</h2>
        <div class="cards">
          <article class="card">
            <h3>Strategy and operations</h3>
            <p>Turn complex situations into clear timelines, decisions, and action plans.</p>
          </article>
          <article class="card">
            <h3>AI and systems</h3>
            <p>Use GPT, Claude, Gemini, and automation tools to reduce friction and improve execution.</p>
          </article>
          <article class="card">
            <h3>Media and signal</h3>
            <p>Shape the message with content systems that support credibility and distribution.</p>
          </article>
          <article class="card">
            <h3>IP defense and platform ops</h3>
            <p>Work with Texas Movement Distribution to keep creator catalogs defended and platform operations under control.</p>
          </article>
          <article class="card">
            <h3>Performance thinking</h3>
            <p>Apply engineering-style analysis to training, routines, and high-output environments.</p>
          </article>
        </div>
      </section>

      <section class="section">
        <h2>Background</h2>
        <div class="bullets">
          <p>Founder and 100% owner of Texas Movement International LLC.</p>
          <p>BS in Civil Engineering, FE passed in 2012.</p>
          <p>Experience across AI consulting, media production, e-commerce operations, IP defense workflows, and legal document support.</p>
          <p>Based in the Chicago area and operating nationally.</p>
        </div>
      </section>

      <section class="section">
        <h2>How I work</h2>
        <div class="bullets">
          <p><strong>Systems first.</strong> I focus on structure, constraints, and durable execution.</p>
          <p><strong>Document before narrative.</strong> The record has to hold up under review.</p>
          <p><strong>Legally in-bounds.</strong> I do not provide legal advice or act as counsel.</p>
          <p><strong>Built for serious work.</strong> I am a fit when the stakes are real and the brief is clear.</p>
        </div>
      </section>

      <section id="keynote" class="section">
        <h2>Keynote and live speaking</h2>
        <div class="cards">
          <article class="card">
            <h3>What I speak about</h3>
            <p>
              Systems for performance, founder economics, IP defense on platforms, AI-assisted operations, and how
              structure changes what people and organizations can actually do.
            </p>
          </article>
          <article class="card">
            <h3>Who it is for</h3>
            <p>
              Conferences, founder summits, corporate offsites, teams, and communities that want a practical, systems-first
              view of performance, AI, and economic leverage — not generic motivation.
            </p>
          </article>
          <article class="card">
            <h3>Format</h3>
            <p>
              Keynotes, fireside conversations, and small-room working sessions. I bias toward sessions that can leave
              people with a usable framework, not just a story.
            </p>
          </article>
          <article class="card">
            <h3>How to request a keynote</h3>
            <p>
              Email a short outline of your event, audience, dates, and what you want people to walk away with to
              <a href="mailto:movementconsultant@gmail.com">movementconsultant@gmail.com</a>. Include “Keynote inquiry”
              in the subject line.
            </p>
          </article>
        </div>
      </section>

      <section id="tm-links" class="section">
        <h2>Texas Movement ecosystem</h2>
        <div class="link-grid">
          <a href="https://texasmovement.com/" target="_blank" rel="noreferrer">TexasMovement.com</a>
          <a href="https://distribution.texasmovement.com/" target="_blank" rel="noreferrer">Texas Movement Distribution</a>
          <a href="https://consulting.texasmovement.com/" target="_blank" rel="noreferrer">Consulting</a>
          <a href="https://media.texasmovement.com/" target="_blank" rel="noreferrer">Media</a>
          <a href="https://performance.texasmovement.com/" target="_blank" rel="noreferrer">Performance</a>
          <a href="https://hero.texasmovement.com/" target="_blank" rel="noreferrer">HERO</a>
          <a href="https://founderlink.texasmovement.com/" target="_blank" rel="noreferrer">FounderLink</a>
        </div>
      </section>

      <section id="socials" class="section">
        <h2>LinkedIn and socials</h2>
        <div class="cards">
          <article class="card">
            <h3>LinkedIn</h3>
            <p>
              For systems threads, AI and operations notes, and founder-focused writing.
              <br />
              <a href="https://www.linkedin.com/in/alexandermathai" target="_blank" rel="noreferrer">
                linkedin.com/in/alexandermathai
              </a>
            </p>
          </article>
          <article class="card">
            <h3>Instagram</h3>
            <p>
              For day-to-day perspective and visuals from Texas Movement.
              <br />
              <a href="https://www.instagram.com/alexanderofnazareth/" target="_blank" rel="noreferrer">
                @alexanderofnazareth
              </a>
            </p>
          </article>
          <article class="card">
            <h3>TikTok</h3>
            <p>
              For short-form systems notes, training, and ecosystem perspective.
              <br />
              <a href="https://www.tiktok.com/@AlexanderVMathai" target="_blank" rel="noreferrer">
                @AlexanderVMathai
              </a>
            </p>
          </article>
          <article class="card">
            <h3>Texas Movement network</h3>
            <p>
              HERO, Texas Movement Media, and Texas Movement Performance each have their own channels.
              Start at
              <a href="https://texasmovement.com" target="_blank" rel="noreferrer">TexasMovement.com</a>
              to see the full list.
            </p>
          </article>
        </div>
      </section>

      <section id="faq" class="section">
        <h2>Frequently asked questions</h2>

        <div class="faq">
          <div class="faq-item">
            <h3>Who is Alexander Mathai?</h3>
            <p>He is the founder of Texas Movement International LLC and the operator behind its consulting, media, performance, IP defense, and systems work.</p>
          </div>

          <div class="faq-item">
            <h3>What does Alexander Mathai do?</h3>
            <p>He builds systems for founders and teams that need help with strategy, AI workflows, media operations, IP defense, and complex execution problems.</p>
          </div>

          <div class="faq-item">
            <h3>What is Texas Movement International LLC?</h3>
            <p>It is the company Alexander founded to organize footwear, performance, media, consulting, IP defense, and related verticals under one operating structure.</p>
          </div>

          <div class="faq-item">
            <h3>Who is this page for?</h3>
            <p>This page is for people who want a clear founder profile, a direct explanation of what he does, and a clean path into the Texas Movement ecosystem.</p>
          </div>
        </div>
      </section>

      <section id="contact" class="section contact">
        <h2>Contact</h2>
        <p>
          Send a brief with context, constraints, and what a good outcome would look like.
        </p>
        <a href="mailto:movementconsultant@gmail.com" class="email">movementconsultant@gmail.com</a>
        <p class="fineprint">
          Please do not send confidential legal information. No attorney-client relationship is formed through this site.
        </p>
      </section>

      <footer class="footer">
        <p>© 2026 Alexander Mathai · Texas Movement International LLC</p>
      </footer>
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    background: #020617;
    color: #e5e7eb;
    font-family: "Inter", system-ui, sans-serif;
    line-height: 1.6;
  }

  .page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.25rem 3rem;
  }

  .topbar,
  .hero,
  .section,
  .footer {
    margin-bottom: 2rem;
  }

  .topbar {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    border-bottom: 1px solid rgba(148, 163, 184, 0.25);
    padding-bottom: 1rem;
  }

  .brand {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .brand-mark {
    width: 2rem;
    height: 2rem;
    border: 1px solid rgba(148, 163, 184, 0.6);
    border-radius: 999px;
    display: grid;
    place-items: center;
  }

  .brand-name {
    font-weight: 700;
    color: #f8fafc;
  }

  .brand-subtitle {
    font-size: 0.9rem;
    color: #94a3b8;
  }

  .nav {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .nav a,
  .link-grid a,
  .email {
    color: #38bdf8;
    text-decoration: none;
  }

  .nav a:hover,
  .link-grid a:hover,
  .email:hover {
    text-decoration: underline;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.9fr);
    gap: 1.5rem;
    align-items: start;
    padding-top: 0.5rem;
  }

  .eyebrow {
    color: #60a5fa;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.78rem;
  }

  h1 {
    font-size: clamp(2.2rem, 4vw, 4rem);
    line-height: 1.05;
    color: #f8fafc;
    margin: 0 0 1rem;
  }

  h2 {
    font-size: 1rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #94a3b8;
    margin-bottom: 1rem;
  }

  h3 {
    margin: 0 0 0.4rem;
    color: #f8fafc;
  }

  .lead,
  .supporting,
  .hero-card-body p,
  .card p,
  .faq-item p,
  .contact p,
  .bullets p {
    color: #cbd5e1;
  }

  .cta-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.25rem;
  }

  .button {
    padding: 0.75rem 1rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
  }

  .primary {
    background: #38bdf8;
    color: #020617;
  }

  .secondary {
    border: 1px solid rgba(148, 163, 184, 0.5);
    color: #e5e7eb;
  }

  .hero-card,
  .card,
  .faq-item,
  .contact {
    border: 1px solid rgba(148, 163, 184, 0.22);
    border-radius: 1rem;
    background: rgba(15, 23, 42, 0.55);
  }

  .hero-card {
    overflow: hidden;
  }

  .portrait-wrap img {
    display: block;
    width: 100%;
    height: auto;
  }

  .hero-card-body {
    padding: 1rem;
  }

  .hero-card-title {
    margin: 0 0 0.35rem;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.78rem;
  }

  .section {
    padding-top: 0.5rem;
  }

  .cards,
  .link-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .card,
  .faq-item {
    padding: 1rem;
  }

  .bullets {
    display: grid;
    gap: 0.75rem;
    max-width: 70ch;
  }

  .faq {
    display: grid;
    gap: 0.75rem;
  }

  .contact {
    padding: 1rem;
  }

  .fineprint {
    font-size: 0.85rem;
    color: #94a3b8;
  }

  .footer {
    border-top: 1px solid rgba(148, 163, 184, 0.25);
    padding-top: 1rem;
    color: #94a3b8;
    font-size: 0.9rem;
  }

  @media (max-width: 800px) {
    .hero,
    .cards,
    .link-grid {
      grid-template-columns: 1fr;
    }

    .topbar {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
