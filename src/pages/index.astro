---
import { AstroSeo } from '@astrojs/seo';

const siteUrl = 'https://alexandermathai.com';
const title =
  'Alexander Mathai — Founder, Texas Movement International';
const description =
  'Alexander Mathai operates Texas Movement International, a systems company for people who move. This is the founder and authority layer: keynotes, operating record, and routes into the ecosystem.';
const ogImage = '/og-alexander-mathai.png';

const twitterHandle = '@alexanderofnazareth';

const linkedinUrl = 'https://www.linkedin.com/in/alexandermathai';
const instagramUrl = 'https://www.instagram.com/alexanderofnazareth/';
const email = 'movementconsultant@gmail.com';
---

<html lang="en">
  <head>
    <AstroSeo
      title={title}
      description={description}
      canonical={siteUrl}
      openGraph={{
        type: 'website',
        url: siteUrl,
        title,
        description,
        images: [
          {
            url: ogImage,
            width: 1200,
            height: 630,
            alt: 'Alexander Mathai, Founder of Texas Movement International',
          },
        ],
      }}
      twitter={{
        card: 'summary_large_image',
        site: twitterHandle,
        title,
        description,
        images: [ogImage],
      }}
    />

    <meta name="theme-color" content="#15181E" />

    <!-- Person + ecosystem schema [file:226][web:3][web:1][web:5] -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "@id": "https://alexandermathai.com/person",
        "name": "Alexander Mathai",
        "url": "https://alexandermathai.com",
        "image": "https://alexandermathai.com/og-alexander-mathai.png",
        "jobTitle": "Founder & President, Texas Movement International",
        "description": "Founder of Texas Movement International, operating systems for performance, media, consulting, distribution, health, reparations, and public layers.",
        "sameAs": [
          "https://www.linkedin.com/in/alexandermathai",
          "https://www.instagram.com/alexanderofnazareth/",
          "https://texasmovement.com"
        ],
        "affiliation": {
          "@type": "Organization",
          "@id": "https://texasmovement.com#org",
          "name": "Texas Movement International LLC",
          "url": "https://texasmovement.com"
        },
        "email": "mailto:movementconsultant@gmail.com"
      }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&family=Space+Grotesk:wght@500;600&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --paper: #e7e8e2;
        --panel: #ddded7;
        --hero: #e9e0d5;
        --hero-soft: #f3ebe2;
        --hero-ink: #15181e;
        --hero-border: #b88d68;
        --ink: #15181e;
        --ink-soft: #454a54;
        --line: #c4c6bd;
        --line-strong: #a6a99f;
        --graphite: #111217;
        --white: #f4f5f0;
        --compression: #274a78;
        --tension: #bd3b22;
        --wrap: 1080px;
        --accent-ink: #1f2937;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
        -webkit-text-size-adjust: 100%;
      }

      body {
        background: var(--paper);
        color: var(--ink);
        font-family: 'IBM Plex Sans', system-ui, sans-serif;
        font-size: 16.5px;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      a:focus-visible {
        outline: 2px solid var(--compression);
        outline-offset: 3px;
      }

      .wrap {
        max-width: var(--wrap);
        margin: 0 auto;
        padding: 0 20px;
      }

      header {
        border-bottom: 1px solid var(--line);
        background: rgba(231, 232, 226, 0.96);
        backdrop-filter: blur(8px);
        position: sticky;
        top: 0;
        z-index: 40;
      }

      .topbar {
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      .brand {
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 600;
        font-size: 1rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
      }

      .brand span {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--ink-soft);
      }

      .brand-mark img {
        height: 28px;
        width: auto;
        border-radius: 999px;
        display: block;
      }

      nav {
        display: flex;
        gap: 18px;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.72rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--ink-soft);
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      nav a:hover {
        color: var(--ink);
      }

      main {
        padding-bottom: 72px;
      }

      .section {
        padding: 72px 0;
      }

      .section--tight {
        padding: 60px 0;
      }

      .section--panel {
        background: var(--panel);
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
      }

      .eyebrow {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.72rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--ink-soft);
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 18px;
      }

      .eyebrow::before {
        content: '';
        width: 32px;
        height: 1px;
        background: var(--tension);
        flex: none;
      }

      h1,
      h2,
      h3 {
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 600;
        line-height: 1.06;
        letter-spacing: -0.02em;
      }

      h1 {
        font-size: clamp(2.4rem, 4.2vw, 3.4rem);
        margin-bottom: 16px;
      }

      h2 {
        font-size: clamp(1.7rem, 3vw, 2.2rem);
        margin-bottom: 16px;
      }

      h3 {
        font-size: 1.1rem;
        margin-bottom: 6px;
      }

      p {
        color: var(--ink-soft);
        max-width: 46em;
      }

      .hero {
        border-bottom: 1px solid var(--line);
        background: linear-gradient(130deg, var(--hero), var(--hero-soft));
      }

      .hero-inner {
        display: grid;
        grid-template-columns: minmax(0, 1.3fr) minmax(0, 0.9fr);
        gap: 40px;
        align-items: center;
      }

      .hero-tagline {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.76rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--ink-soft);
        margin-bottom: 10px;
      }

      .hero-body {
        font-size: 1.02rem;
        margin-bottom: 16px;
      }

      .hero-note {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--ink-soft);
        margin-top: 10px;
      }

      .hero-ctas {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 18px;
      }

      .btn {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.78rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        padding: 11px 18px;
        border-radius: 999px;
        border: 1px solid var(--accent-ink);
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--accent-ink);
        color: var(--white);
        transition: 0.18s ease;
      }

      .btn:hover {
        background: transparent;
        color: var(--accent-ink);
      }

      .btn--ghost {
        background: transparent;
        color: var(--accent-ink);
      }

      .btn--ghost:hover {
        background: var(--accent-ink);
        color: var(--white);
      }

      .btn .arrow {
        transition: transform 0.16s ease;
      }

      .btn:hover .arrow {
        transform: translateX(3px);
      }

      .hero-photo {
        position: relative;
        border-radius: 18px;
        overflow: hidden;
        border: 1px solid var(--line-strong);
        background: #d8dad1;
      }

      .hero-photo img {
        display: block;
        width: 100%;
        height: auto;
      }

      .hero-photo-caption {
        position: absolute;
        bottom: 10px;
        right: 14px;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.68rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--ink-soft);
        background: rgba(231, 232, 226, 0.86);
        padding: 4px 8px;
        border-radius: 999px;
        border: 1px solid var(--line);
      }

      .grid-2 {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
        gap: 40px;
        align-items: flex-start;
      }

      .cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 18px;
        margin-top: 18px;
      }

      .card {
        border-radius: 14px;
        border: 1px solid var(--line-strong);
        background: var(--paper);
        padding: 16px 16px 14px;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }

      .card-label {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--ink-soft);
      }

      .card-title {
        font-size: 1.02rem;
        font-weight: 600;
      }

      .card-body {
        font-size: 0.9rem;
        color: var(--ink-soft);
      }

      .cta-link {
        margin-top: 6px;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.78rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .cta-link a {
        border-bottom: 1px solid transparent;
      }

      .cta-link a:hover {
        border-bottom-color: var(--accent-ink);
      }

      .social-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 16px;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.78rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .social-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 12px;
        border-radius: 999px;
        border: 1px solid var(--line-strong);
        background: var(--paper);
        color: var(--ink-soft);
      }

      .social-pill:hover {
        border-color: var(--accent-ink);
        color: var(--accent-ink);
      }

      .faq-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 18px;
        margin-top: 20px;
      }

      .faq-item {
        border-radius: 14px;
        border: 1px solid var(--line-strong);
        padding: 16px 16px 14px;
        background: var(--paper);
        font-size: 0.9rem;
        color: var(--ink-soft);
      }

      footer {
        padding: 24px 0 30px;
        background: var(--graphite);
        color: #9aa0ab;
        border-top: 1px solid #2c313b;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.06em;
      }

      .footer-inner {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 10px;
        align-items: center;
      }

      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 8px 14px;
      }

      .footer-links a:hover {
        color: #e5e7eb;
      }

      @media (max-width: 900px) {
        .hero-inner {
          grid-template-columns: 1fr;
        }

        .grid-2 {
          grid-template-columns: 1fr;
        }

        nav {
          display: none;
        }

        .wrap {
          padding: 0 18px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
      }
    </style>
  </head>

  <body>
    <header>
      <div class="wrap">
        <div class="topbar">
          <a href="#top" class="brand" aria-label="Alexander Mathai home">
            <span class="brand-mark">
              <img
                src="/AVM-Blue-turtleneck-standing-arm-cross.jpg"
                alt="Alexander Mathai, arms crossed in blue turtleneck"
              />
            </span>
            <span>ALEXANDER MATHAI</span>
          </a>
          <nav>
            <a href="#overview">Overview</a>
            <a href="#keynote">Keynotes</a>
            <a href="#systems">Systems work</a>
            <a href="#ecosystem">Ecosystem</a>
            <a href="#faq">FAQ</a>
            <a href="#contact">Contact</a>
          </nav>
        </div>
      </div>
    </header>

    <main id="top">
      <!-- Hero / authority layer [file:226][web:3][web:1] -->
      <section id="overview" class="section hero">
        <div class="wrap hero-inner">
          <div>
            <div class="hero-tagline">
              FOUNDER · SYSTEMS · TEXAS MOVEMENT INTERNATIONAL.
            </div>
            <h1>The founder and authority layer of Texas Movement.</h1>
            <p class="hero-body">
              I build systems for people and institutions who have real stakes:
              athletes, founders, cities, and families. Texas Movement International
              is the company. This page is the personal authority layer that explains
              how I think, how I work, and where to route serious work.
            </p>
            <p class="hero-body">
              It exists so collaborators, clients, and teams can see the operating
              record in one place—then enter the right lane: Consulting for systems,
              Performance and Health for the physical layer, Media for signal,
              Distribution for rights and catalog, FounderLink for intake, Social
              for events, and Reparations for structural analysis.
            </p>
            <div class="hero-ctas">
              <a class="btn" href="#keynote">
                Keynote & live speaking <span class="arrow">→</span>
              </a>
              <a class="btn btn--ghost" href="#contact">
                Send a brief <span class="arrow">→</span>
              </a>
            </div>
            <div class="hero-note">
              ONE FOUNDER · ONE SYSTEM · SEVERAL LANES · BUILT FOR SERIOUS WORK
            </div>

            <div class="social-row">
              <a
                class="social-pill"
                href={linkedinUrl}
                target="_blank"
                rel="noreferrer"
              >
                <span>LinkedIn</span> <span>↗</span>
              </a>
              <a
                class="social-pill"
                href={instagramUrl}
                target="_blank"
                rel="noreferrer"
              >
                <span>Instagram</span> <span>@alexanderofnazareth</span>
              </a>
              <a
                class="social-pill"
                href="https://texasmovement.com"
                target="_blank"
                rel="noreferrer"
              >
                <span>TexasMovement.com</span> <span>ecosystem hub</span>
              </a>
            </div>
          </div>

          <aside class="hero-photo">
            <img
              src="/AVM-Blue-turtleneck-standing-arm-cross.jpg"
              alt="Alexander Mathai standing in blue turtleneck with arms crossed"
              loading="lazy"
            />
            <div class="hero-photo-caption">
              FIG. 01 — FOUNDER · AUTHORITY LAYER
            </div>
          </aside>
        </div>
      </section>

      <!-- Keynote & live speaking [file:226][web:3] -->
      <section id="keynote" class="section section--panel">
        <div class="wrap grid-2">
          <div>
            <div class="eyebrow">KEYNOTES & LIVE WORK</div>
            <h2>Systems, performance, AI, and economic leverage for serious rooms.</h2>
            <p>
              Keynote and live speaking are for conferences, offsites, and rooms
              where people are actually making decisions. Topics cover systems for
              founders, AI and operations, performance and recovery, and
              long-horizon economic leverage.
            </p>
            <p>
              Every keynote is scoped like consulting work: clear constraints,
              outcomes, and accountability. The point is not a talk that sounds
              good—for a day—but a session that changes how people see their
              operating system.
            </p>

            <p class="cta-link">
              <a href={`mailto:${email}?subject=Keynote%20inquiry`}>
                Email a keynote inquiry →
              </a>
            </p>
          </div>

          <aside>
            <div class="cards-grid">
              <article class="card">
                <div class="card-label">Angle</div>
                <div class="card-title">Systems for founders.</div>
                <p class="card-body">
                  How to turn messy problems into systems you can run—constraints,
                  sequencing, and the operating record that survives review.
                </p>
              </article>
              <article class="card">
                <div class="card-label">Angle</div>
                <div class="card-title">AI and operations.</div>
                <p class="card-body">
                  How to use AI inside systems so it reduces friction instead of
                  creating new chaos. Workflows and decision paths, not hype.
                </p>
              </article>
              <article class="card">
                <div class="card-label">Angle</div>
                <div class="card-title">Performance and recovery.</div>
                <p class="card-body">
                  Training, movement, and herbs-only recovery as one system for
                  people with real output demands—not wellness for its own sake.
                </p>
              </article>
              <article class="card">
                <div class="card-label">Angle</div>
                <div class="card-title">Economic leverage.</div>
                <p class="card-body">
                  How structure, rights, and signal create leverage over decades,
                  not weeks. What it means to build with real stakes in view.
                </p>
              </article>
            </div>
          </aside>
        </div>
      </section>

      <!-- Systems work & operating record [file:226][web:3][web:1] -->
      <section id="systems" class="section">
        <div class="wrap">
          <div class="eyebrow">SYSTEMS WORK</div>
          <h2>How I work, and where that work lives in the ecosystem.</h2>
          <p>
            The work lives across several lanes. Consulting handles systems and
            AI workflows. Performance and Health handle the physical and recovery
            layer. Media handles signal. Distribution handles rights and catalog.
            FounderLink handles intake. Social and Reparations handle public and
            structural questions.
          </p>
          <p>
            The operating idea is simple: each lane does one thing clearly, and
            all of them share one founder, one spine, and one standard for serious
            work. You enter through the lane you need—or through FounderLink if
            you want to be routed.
          </p>

          <div class="cards-grid">
            <article class="card">
              <div class="card-label">Lane</div>
              <div class="card-title">Texas Movement Consulting.</div>
              <p class="card-body">
                Systems and AI workflows for founders and operators. Scoped
                diagnostics, systems builds, and operator retainers for work that
                needs structure.
              </p>
              <p class="cta-link">
                <a href="https://consulting.texasmovement.com" target="_blank" rel="noreferrer">
                  Open consulting.texasmovement.com →
                </a>
              </p>
            </article>

            <article class="card">
              <div class="card-label">Lane</div>
              <div class="card-title">Texas Movement Performance & Health.</div>
              <p class="card-body">
                Training systems, biomechanics, and herbs-only recovery protocols
                for athletes and serious movers who treat training like engineering.
              </p>
              <p class="cta-link">
                <a href="https://performance.texasmovement.com" target="_blank" rel="noreferrer">
                  Performance layer →
                </a>
                &nbsp;&nbsp;
                <a href="https://health.texasmovement.com" target="_blank" rel="noreferrer">
                  Health layer →
                </a>
              </p>
            </article>

            <article class="card">
              <div class="card-label">Lane</div>
              <div class="card-title">Media, Distribution, and Social.</div>
              <p class="card-body">
                Documentation and signal through Texas Movement Media, rights and
                catalog operations through Distribution, and public events and
                graph through Social / Gather.
              </p>
              <p class="cta-link">
                <a href="https://media.texasmovement.com" target="_blank" rel="noreferrer">
                  Media →
                </a>
                &nbsp;&nbsp;
                <a href="https://distribution.texasmovement.com" target="_blank" rel="noreferrer">
                  Distribution →
                </a>
                &nbsp;&nbsp;
                <a href="https://social.texasmovement.com" target="_blank" rel="noreferrer">
                  Social →
                </a>
              </p>
            </article>

            <article class="card">
              <div class="card-label">Lane</div>
              <div class="card-title">FounderLink and Reparations.</div>
              <p class="card-body">
                FounderLink as the intake and routing layer, and Texas Movement
                Reparations Partners as the structural analysis lane on economic
                repair and long-horizon questions.
              </p>
              <p class="cta-link">
                <a href="https://founderlink.texasmovement.com" target="_blank" rel="noreferrer">
                  FounderLink →
                </a>
                &nbsp;&nbsp;
                <a href="https://reparations.texasmovement.com" target="_blank" rel="noreferrer">
                  Reparations →
                </a>
              </p>
            </article>
          </div>
        </div>
      </section>

      <!-- Ecosystem connection [file:226][web:12] -->
      <section id="ecosystem" class="section section--panel">
        <div class="wrap">
          <div class="eyebrow">ECOSYSTEM</div>
          <h2>One founder. One company. Several lanes that compound.</h2>
          <p>
            Texas Movement International is the company layer. It runs several
            lanes—HERO for product, Performance and Health for the physical and
            recovery layer, Media for signal, Consulting for systems, Distribution
            for rights and catalog, FounderLink for intake, Social for public, and
            Reparations for structural analysis.
          </p>
          <p>
            This page is the authority layer that sits above that system. If you
            want the ecosystem overview, go to TexasMovement.com. If you want
            intake, go to FounderLink. If you want to see how I think, read this
            page and follow the signals and lanes that fit.
          </p>
          <p class="cta-link">
            <a href="https://texasmovement.com" target="_blank" rel="noreferrer">
              Open TexasMovement.com (hub) →
            </a>
          </p>
        </div>
      </section>

      <!-- FAQ [file:226][web:3][web:1] -->
      <section id="faq" class="section section--tight">
        <div class="wrap">
          <div class="eyebrow">FAQ</div>
          <h2>Frequently asked questions.</h2>
          <div class="faq-grid">
            <div class="faq-item">
              <h3>What is this page?</h3>
              <p>
                The founder and authority layer of Texas Movement International.
                It explains how I work, how the ecosystem is structured, and how
                to route serious work.
              </p>
            </div>
            <div class="faq-item">
              <h3>How do I work with you directly?</h3>
              <p>
                Most serious work routes through Texas Movement lanes, especially
                Consulting and FounderLink. Keynotes and select collaborations
                start with a brief sent via email.
              </p>
            </div>
            <div class="faq-item">
              <h3>Is this a personal brand site?</h3>
              <p>
                No. It is an operating record and authority layer. It exists to
                connect real work to the right lanes, not to collect attention
                without a system behind it.
              </p>
            </div>
            <div class="faq-item">
              <h3>Where should I follow ongoing thinking?</h3>
              <p>
                LinkedIn and Texas Movement Media carry most of the structured
                thinking in public. Instagram is where some of the texture and
                in-between live.
              </p>
