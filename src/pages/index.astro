---
const title = "Alexander Varghese Mathai · Texas Movement International";
const description =
  "Founder and 100% owner of Texas Movement International — building systems for performance, media, footwear, AI consulting, and economic development.";
const url = "https://alexandermathai.com";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:image" content="/og-alexander-mathai.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-alexander-mathai.png" />

    <!-- Font: Inter -->
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <main class="page">
      <header class="site-header">
        <div class="site-header-left">
          <span class="site-mark">A</span>
          <div class="site-title-block">
            <div class="site-name">Alexander Varghese Mathai</div>
            <div class="site-company">Texas Movement International</div>
          </div>
        </div>
        <nav class="site-nav">
          <a href="#thesis">Thesis</a>
          <a href="#ecosystem">Ecosystem</a>
          <a href="#cases">Receipts</a>
          <a href="#contact">Contact</a>
        </nav>
      </header>

      <section class="layout">
        <!-- MAIN COLUMN -->
        <div class="layout-main">
          <section id="thesis" class="hero">
            <div class="hero-copy">
              <p class="eyebrow">OPERATOR FOR HIGH-STAKES PEOPLE</p>
              <h1 class="hero-title">
                I build<br />
                <span class="hero-accent">systems</span><br />
                for people who cannot afford to lose.
              </h1>
              <p class="hero-body">
                I’m Alexander Varghese Mathai, founder and 100% owner of
                <strong>Texas Movement International</strong> — a multi-vertical
                systems company building infrastructure for performance, media,
                footwear, AI consulting, and economic development so athletes,
                founders, cities, and families can move with more stability and
                upside.
              </p>
              <div class="hero-cta-row">
                <a
                  href="https://consulting.texasmovement.com/"
                  class="button primary"
                  target="_blank"
                  rel="noreferrer"
                >
                  Book a working session ↗
                </a>
                <a
                  href="mailto:alexander@texasmovement.com"
                  class="button secondary"
                >
                  Send a direct brief
                </a>
              </div>
            </div>

            <div class="hero-aside">
              <div class="portrait-wrap">
                <img
                  src="/AVM-Blue-turtleneck-standing-arm-cross.jpg"
                  alt="Portrait of Alexander Varghese Mathai"
                  class="portrait"
                  loading="lazy"
                />
              </div>
              <p class="hero-tagline">
                Most people optimize for looking big. I optimize for being the
                person you call when a landlord, platform, or institution is
                quietly eating your upside. The work shows up in your movement,
                your systems, and how your paperwork holds when someone tests it.
              </p>
            </div>
          </section>

          <section class="metrics">
            <div class="metric">
              <div class="metric-label">IN UNDERLYING VALUE TOUCHED ACROSS CASES & PROJECTS*</div>
              <div class="metric-value">$800K+</div>
            </div>
            <div class="metric">
              <div class="metric-label">AI-ASSISTED PROJECTS & EXPERIMENTS SHIPPED</div>
              <div class="metric-value">100+</div>
            </div>
            <div class="metric">
              <div class="metric-label">IN ENGINEERING, MEDIA & LEGAL TRENCHES</div>
              <div class="metric-value">12 years</div>
            </div>
          </section>

          <section id="cases" class="section">
            <h2 class="section-title">Receipts (abridged)</h2>

            <div class="section-group">
              <div class="section-label">HOUSING</div>
              <div class="section-subtitle">CIVIL RIGHTS / TENANT LEVERAGE</div>
              <ul class="bullet-list">
                <li>
                  <strong>Tenant leverage build-out</strong> — Structured
                  documentation and motion strategy in disputes with tens of
                  thousands in housing value at stake — turning vague grievances
                  into paper the court can act on.
                </li>
              </ul>
            </div>

            <div class="section-group">
              <div class="section-label">AI / OPS</div>
              <div class="section-subtitle">FOUNDER SYSTEMS</div>
              <ul class="bullet-list">
                <li>
                  <strong>Founder ops compression</strong> — Wired AI into
                  outreach, content, and operations for early-stage operators so
                  they can spend more time on leverage instead of inbox warfare.
                </li>
              </ul>
            </div>

            <div class="section-group">
              <div class="section-label">PERFORMANCE</div>
              <div class="section-subtitle">SPRINT & MOVEMENT DESIGN</div>
              <ul class="bullet-list">
                <li>
                  <strong>Sprint-first diagnostics</strong> — Biomechanics-first
                  lens applied to training and daily movement, then mapped into
                  how people design their systems and contracts.
                </li>
              </ul>
            </div>
          </section>

          <section class="section">
            <h2 class="section-title">Background</h2>
            <ul class="bullet-list">
              <li>BS Civil Engineering (FE passed 2012).</li>
              <li>Hands-on AI consulting, e-commerce, and media production.</li>
              <li>
                Drafting & coordinating complex motions and complaints as a pro
                se litigant working with attorneys.
              </li>
            </ul>
          </section>

          <section id="contact" class="section">
            <h2 class="section-title">Contact</h2>
            <p class="copy">
              Prefer signal over noise. Send context, not a cold pitch.
            </p>
            <a href="mailto:alexander@texasmovement.com" class="contact-link">
              alexander@texasmovement.com
            </a>
          </section>
        </div>

        <!-- SIDEBAR -->
        <aside class="sidebar">
          <section class="sidebar-card">
            <h2 class="sidebar-title">Founder profile</h2>
            <p class="sidebar-name">Alexander Varghese Mathai</p>
            <p class="sidebar-role">
              Founder & 100% owner, Texas Movement International LLC
            </p>
            <ul class="sidebar-list">
              <li>AI systems & automation</li>
              <li>Civil engineering mindset</li>
              <li>Pro se legal strategy</li>
              <li>Sprints & performance design</li>
            </ul>
          </section>

          <section class="sidebar-card">
            <h3 class="sidebar-subtitle">Selected systems</h3>
            <ul class="sidebar-list">
              <li>
                <strong>AI consulting stack for founders</strong> — Reusable GPT /
                Claude / Gemini stack that turns messy founder ideas into briefs,
                decision docs, and shipping calendars.
              </li>
              <li>
                <strong>Media engine for long-form & shorts</strong> — Workflows
                that turn one deep session into LinkedIn scripts, YouTube talks,
                and TikTok clips without burning the operator out.
              </li>
              <li>
                <strong>Legal documentation frameworks</strong> — Structures for
                civil rights and landlord/tenant filings that keep receipts tight
                and timelines aggressive.
              </li>
            </ul>
          </section>

          <section class="sidebar-card sidebar-meta">
            <p class="meta-line">
              Based in Chicago · Operating nationally.
            </p>
            <p class="meta-links">
              <a href="https://texasmovement.com/" target="_blank" rel="noreferrer">
                TexasMovement.com
              </a>
              ·
              <a
                href="https://consulting.texasmovement.com/"
                target="_blank"
                rel="noreferrer"
              >
                Texas Movement Consulting
              </a>
              ·
              <a
                href="https://www.linkedin.com/in/alexandermathai"
                target="_blank"
                rel="noreferrer"
              >
                LinkedIn
              </a>
            </p>
          </section>
        </aside>
      </section>

      <section id="ecosystem" class="ecosystem">
        <div class="ecosystem-header">
          <h2 class="section-title">Texas Movement International ecosystem</h2>
          <p class="ecosystem-subtitle">
            Systems for people who move — one company, multiple verticals under load.
          </p>
        </div>

        <div class="ecosystem-grid">
          <article class="ecosystem-card">
            <div class="ecosystem-label">TEXAS MOVEMENT SOCIAL / GATHER™</div>
            <h3 class="ecosystem-title">Ceremony & experience, powered by Circle OS™.</h3>
            <p class="ecosystem-body">
              Ceremony and experience platform for couples, families, and communities — built
              on Circle OS™ so moments turn into durable structure.
            </p>
            <a
              href="https://social.texasmovement.com/"
              class="ecosystem-link"
              target="_blank"
              rel="noreferrer"
            >
              Social.TexasMovement.com →
            </a>
          </article>

          <article class="ecosystem-card">
            <div class="ecosystem-label">TEXAS MOVEMENT MEDIA</div>
            <h3 class="ecosystem-title">Content as economic leverage.</h3>
            <p class="ecosystem-body">
              Pro talks, underreported sports, and founder stories turned into economic
              leverage for athletes, brands, and cities.
            </p>
            <div class="ecosystem-links-row">
              <a
                href="https://www.youtube.com/@TexasMovementMedia"
                target="_blank"
                rel="noreferrer"
              >
                YouTube
              </a>
              <span class="ecosystem-dot">·</span>
              <a
                href="https://media.texasmovement.com/"
                target="_blank"
                rel="noreferrer"
              >
                Media.TexasMovement.com →
              </a>
            </div>
          </article>

          <article class="ecosystem-card">
            <div class="ecosystem-label">HERO FOOTWEAR & PERFORMANCE</div>
            <h3 class="ecosystem-title">Footwear engineered around biomechanics.</h3>
            <p class="ecosystem-body">
              Footwear and training systems for athletes who operate at the edge — sprint
              plates and protocols built from first principles.
            </p>
            <div class="ecosystem-links-row">
              <a
                href="https://www.instagram.com/herofootwearusa/"
                target="_blank"
                rel="noreferrer"
              >
                Instagram
              </a>
              <span class="ecosystem-dot">·</span>
              <a
                href="https://www.tiktok.com/@herofootwear"
                target="_blank"
                rel="noreferrer"
              >
                TikTok
              </a>
              <span class="ecosystem-dot">·</span>
              <a
                href="https://www.youtube.com/@HEROFootwear"
                target="_blank"
                rel="noreferrer"
              >
                YouTube
              </a>
              <span class="ecosystem-dot">·</span>
              <a
                href="https://hero.texasmovement.com/"
                target="_blank"
                rel="noreferrer"
              >
                HERO.TexasMovement.com →
              </a>
            </div>
          </article>

          <article class="ecosystem-card">
            <div class="ecosystem-label">TM CONSULTING</div>
            <h3 class="ecosystem-title">AI systems & city-scale work.</h3>
            <p class="ecosystem-body">
              AI project consulting and organizational systems built on a biomechanics-first
              diagnostic framework, for founders and institutions that need real leverage.
            </p>
            <a
              href="https://consulting.texasmovement.com/"
              class="ecosystem-link"
              target="_blank"
              rel="noreferrer"
            >
              Consulting.TexasMovement.com →
            </a>
          </article>

          <article class="ecosystem-card">
            <div class="ecosystem-label">FOUNDERLINK</div>
            <h3 class="ecosystem-title">Operating playbooks & capital pathways.</h3>
            <p class="ecosystem-body">
              Operating playbooks and capital pathways for founders who ship — connecting
              builders to the infrastructure they actually need.
            </p>
            <a
              href="https://founderlink.texasmovement.com/"
              class="ecosystem-link"
              target="_blank"
              rel="noreferrer"
            >
              FounderLink.TexasMovement.com →
            </a>
          </article>

          <article class="ecosystem-card">
            <div class="ecosystem-label">TM REPARATIONS & PARTNERS</div>
            <h3 class="ecosystem-title">Reparative capital & infrastructure.</h3>
            <p class="ecosystem-body">
              Applied economics and infrastructure-first capital strategy at the intersection
              of culture, community, and long-term development.
            </p>
            <a
              href="https://reparations.texasmovement.com/"
              class="ecosystem-link"
              target="_blank"
              rel="noreferrer"
            >
              Reparations.TexasMovement.com →
            </a>
          </article>

          <article class="ecosystem-card">
            <div class="ecosystem-label">TM PERFORMANCE</div>
            <h3 class="ecosystem-title">Training systems & recovery protocols.</h3>
            <p class="ecosystem-body">
              Training systems and recovery protocols engineered from first principles —
              built to be repeatable at every level.
            </p>
            <a
              href="https://performance.texasmovement.com/"
              class="ecosystem-link"
              target="_blank"
              rel="noreferrer"
            >
              Performance.TexasMovement.com →
            </a>
          </article>

          <article class="ecosystem-card">
            <div class="ecosystem-label">FLAGSHIP CREATOR / FOUNDER</div>
            <h3 class="ecosystem-title">Alexander Mathai</h3>
            <p class="ecosystem-body">
              Founder’s perspective on training, builds, and operating inside a multi-vertical
              system.
            </p>
            <div class="ecosystem-links-row">
              <a
                href="https://www.instagram.com/alexanderofnazareth/"
                target="_blank"
                rel="noreferrer"
              >
                Instagram — @alexanderofnazareth
              </a>
              <span class="ecosystem-dot">·</span>
              <a
                href="https://www.tiktok.com/@alexandervmathai"
                target="_blank"
                rel="noreferrer"
              >
                TikTok — @alexandervmathai
              </a>
            </div>
          </article>
        </div>
      </section>

      <footer class="footer">
        <div class="footer-dot">●</div>
        <p class="footer-note">
          Under active iteration – I ship, then refine.
        </p>
        <p class="footer-meta">
          © 2026 Alexander Varghese Mathai · Texas Movement International LLC
        </p>
      </footer>
    </main>
  </body>

  <style>
    :global(body) {
      margin: 0;
      min-height: 100vh;
      background: #020617;
      color: #e5e7eb;
      font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont,
        "Segoe UI", sans-serif;
    }

    .page {
      max-width: 1120px;
      margin: 0 auto;
      padding: 2.5rem 1.5rem 3.5rem;
      line-height: 1.7;
    }

    .site-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid rgba(148, 163, 184, 0.3);
      margin-bottom: 2.5rem;
    }

    .site-header-left {
      display: flex;
      align-items: center;
      gap: 0.9rem;
    }

    .site-mark {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      border-radius: 999px;
      border: 1px solid rgba(148, 163, 184, 0.7);
      font-size: 0.75rem;
      letter-spacing: 0.08em;
      color: #e5e7eb;
    }

    .site-title-block {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }

    .site-name {
      font-size: 0.95rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #f9fafb;
    }

    .site-company {
      font-size: 0.85rem;
      color: #9ca3af;
    }

    .site-nav {
      display: flex;
      gap: 1.5rem;
      font-size: 0.9rem;
    }

    .site-nav a {
      color: #9ca3af;
      text-decoration: none;
    }

    .site-nav a:hover {
      color: #f9fafb;
    }

    .layout {
      display: grid;
      grid-template-columns: minmax(0, 2.1fr) minmax(0, 1.2fr);
      gap: 2.5rem;
      margin-top: 2.5rem;
    }

    .layout-main {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
    }

    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1.45fr) minmax(0, 1fr);
      gap: 2rem;
      align-items: start;
    }

    .eyebrow {
      font-size: 0.8rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #60a5fa;
      margin-bottom: 0.9rem;
    }

    .hero-title {
      font-size: 2.4rem;
      line-height: 1.15;
      letter-spacing: -0.03em;
      margin: 0 0 1.2rem;
      color: #f9fafb;
    }

    .hero-accent {
      color: #38bdf8;
    }

    .hero-body {
      font-size: 0.98rem;
      color: #d1d5db;
      margin: 0 0 1.6rem;
    }

    .hero-cta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.9rem;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.55rem 1.1rem;
      border-radius: 999px;
      font-size: 0.9rem;
      font-weight: 500;
      text-decoration: none;
      border: 1px solid transparent;
      cursor: pointer;
      transition: background 0.16s ease, color 0.16s ease,
        border-color 0.16s ease, transform 0.12s ease;
    }

    .button.primary {
      background: #38bdf8;
      color: #020617;
    }

    .button.primary:hover {
      background: #0ea5e9;
      transform: translateY(-1px);
    }

    .button.secondary {
      background: transparent;
      border-color: rgba(148, 163, 184, 0.7);
      color: #e5e7eb;
    }

    .button.secondary:hover {
      border-color: #e5e7eb;
      background: rgba(15, 23, 42, 0.9);
    }

    .hero-aside {
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
    }

    .portrait-wrap {
      border-radius: 0.75rem;
      overflow: hidden;
      border: 1px solid rgba(148, 163, 184, 0.4);
      background: radial-gradient(circle at top, #1e293b, #020617);
    }

    .portrait {
      display: block;
      width: 100%;
      height: auto;
      object-fit: cover;
    }

    .hero-tagline {
      font-size: 0.9rem;
      color: #9ca3af;
      margin: 0;
    }

    .metrics {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.2rem;
      padding: 1.2rem 1.1rem;
      border-radius: 0.9rem;
      border: 1px solid rgba(148, 163, 184, 0.4);
      background: radial-gradient(circle at top left, #020617, #020617),
        linear-gradient(
          135deg,
          rgba(37, 99, 235, 0.16),
          rgba(8, 47, 73, 0.45)
        );
    }

    .metric {
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
    }

    .metric-label {
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #9ca3af;
    }

    .metric-value {
      font-size: 1.2rem;
      font-weight: 600;
      color: #f9fafb;
    }

    .section {
      padding-top: 0.5rem;
      border-top: 1px solid rgba(148, 163, 184, 0.25);
    }

    .section + .section {
      margin-top: 1.8rem;
    }

    .section-title {
      font-size: 1.05rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #9ca3af;
      margin: 0 0 1rem;
    }

    .section-group {
      margin-bottom: 1.4rem;
    }

    .section-label {
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #60a5fa;
      margin-bottom: 0.15rem;
    }

    .section-subtitle {
      font-size: 0.9rem;
      font-weight: 500;
      color: #e5e7eb;
      margin-bottom: 0.45rem;
    }

    .bullet-list {
      list-style: disc;
      padding-left: 1.2rem;
      margin: 0.2rem 0 0;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      color: #d1d5db;
      font-size: 0.92rem;
    }

    .copy {
      margin: 0 0 0.5rem;
      color: #d1d5db;
      font-size: 0.95rem;
    }

    .contact-link {
      font-size: 0.95rem;
      color: #38bdf8;
      text-decoration: none;
    }

    .contact-link:hover {
      text-decoration: underline;
    }

    .sidebar {
      display: flex;
      flex-direction: column;
      gap: 1.6rem;
    }

    .sidebar-card {
      padding: 1.1rem 1.1rem 1.05rem;
      border-radius: 0.9rem;
      border: 1px solid rgba(148, 163, 184, 0.4);
      background: radial-gradient(circle at top left, #020617, #020617),
        linear-gradient(
          135deg,
          rgba(15, 23, 42, 0.9),
          rgba(15, 23, 42, 0.98)
        );
    }

    .sidebar-title {
      font-size: 0.95rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #9ca3af;
      margin: 0 0 0.6rem;
    }

    .sidebar-name {
      font-size: 1rem;
      font-weight: 600;
      color: #f9fafb;
      margin: 0 0 0.25rem;
    }

    .sidebar-role {
      font-size: 0.9rem;
      color: #d1d5db;
      margin: 0 0 0.7rem;
    }

    .sidebar-subtitle {
      font-size: 0.9rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #9ca3af;
      margin: 0 0 0.6rem;
    }

    .sidebar-list {
      list-style: disc;
      padding-left: 1.1rem;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
      font-size: 0.9rem;
      color: #d1d5db;
    }

    .sidebar-meta {
      font-size: 0.88rem;
      color: #9ca3af;
    }

    .meta-line {
      margin: 0 0 0.4rem;
    }

    .meta-links {
      margin: 0;
    }

    .meta-links a {
      color: #e5e7eb;
      text-decoration: none;
    }

    .meta-links a:hover {
      text-decoration: underline;
    }

    .ecosystem {
      margin-top: 3rem;
      padding-top: 2.2rem;
      border-top: 1px solid rgba(148, 163, 184, 0.3);
    }

    .ecosystem-header {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      margin-bottom: 1.7rem;
    }

    .ecosystem-subtitle {
      font-size: 0.95rem;
      color: #d1d5db;
      margin: 0;
      max-width: 32rem;
    }

    .ecosystem-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.35rem;
    }

    .ecosystem-card {
      padding: 1.1rem 1rem 1rem;
      border-radius: 0.9rem;
