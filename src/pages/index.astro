---
const title = "Alexander V. Mathai · Systems Engineer & Strategic Advisor";
const description =
  "Alexander V. Mathai is a civil-engineering trained founder and systems engineer who advises on complex workflows, disputes, and performance operations for operators, legal teams, and brands.";
const url = "https://alexandermathai.com";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:image" content="/og-alexander-mathai.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-alexander-mathai.png" />

    <!-- Font: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <main class="page">
      <header class="site-header">
        <div class="site-header-left">
          <span class="site-mark">A</span>
          <div class="site-title-block">
            <div class="site-name">Alexander V. Mathai</div>
            <div class="site-company">Systems Engineer & Strategic Advisor</div>
          </div>
        </div>
        <nav class="site-nav">
          <a href="#overview">Overview</a>
          <a href="#work">Work</a>
          <a href="#ecosystem">TMI Ecosystem</a>
          <a href="#contact">Contact</a>
        </nav>
      </header>

      <section class="layout">
        <!-- MAIN COLUMN -->
        <div class="layout-main">
          <section id="overview" class="hero">
            <div class="hero-copy">
              <p class="eyebrow">HIGH-STAKES SYSTEMS OPERATOR</p>
              <h1 class="hero-title">
                I design<br />
                <span class="hero-accent">systems</span><br />
                for people who run out of excuses.
              </h1>
              <p class="hero-body">
                I’m Alexander V. Mathai — a civil-engineering trained founder and
                systems engineer. I work with operators, legal teams, and brands
                facing complex workflows, disputes, and performance problems
                where the margin for error is thin and the story has to hold up
                under pressure.
              </p>
              <p class="hero-body hero-body-secondary">
                Texas Movement International LLC is the boring, durable company
                under the hood. This site is the operator profile: the person you
                call when you need the build to work on paper, on camera, and in
                records — whether I’m in the room or not.
              </p>
              <div class="hero-cta-row">
                <a href="#contact" class="button primary">
                  Request a strategy call
                </a>
                <a
                  href="mailto:movementconsultant@gmail.com"
                  class="button secondary"
                >
                  Send a brief
                </a>
              </div>
            </div>

            <div class="hero-aside">
              <div class="portrait-wrap">
                <img
                  src="/AVM-Blue-turtleneck-standing-arm-cross.jpg"
                  alt="Portrait of Alexander V. Mathai"
                  class="portrait"
                  loading="lazy"
                />
              </div>
              <p class="hero-tagline">
                I take the risks in the design, not in the integrity. The mandate
                is simple: build structures that let serious people move
                aggressively without crossing the line — so the work survives
                scrutiny when nobody is there to explain it.
              </p>
            </div>
          </section>

          <section class="metrics">
            <div class="metric">
              <div class="metric-label">
                APPROX. VALUE AT STAKE ACROSS SELECT MATTERS*
              </div>
              <div class="metric-value">$800K+</div>
            </div>
            <div class="metric">
              <div class="metric-label">AI / SYSTEMS PROJECTS & EXPERIMENTS</div>
              <div class="metric-value">100+</div>
            </div>
            <div class="metric">
              <div class="metric-label">
                YEARS IN ENGINEERING, MEDIA & LEGAL TRENCHES
              </div>
              <div class="metric-value">12</div>
            </div>
          </section>
          <p class="metrics-footnote">
            *Indicative — based on approximate value at stake across selected
            projects and disputes. Not a guarantee or representation of outcome.
          </p>

          <section id="work" class="section">
            <h2 class="section-title">Selected work lanes</h2>

            <div class="section-group">
              <div class="section-label">STRATEGY & DISPUTES</div>
              <div class="section-subtitle">
                STRUCTURE UNDER ADVERSITY
              </div>
              <ul class="bullet-list">
                <li>
                  <strong>Complex-matter mapping</strong> — Turning multi-front
                  disputes and operational chaos into clean timelines, issue maps,
                  and decision trees that licensed counsel and executives can
                  actually use.
                </li>
                <li>
                  <strong>Evidence & workflow design</strong> — Designing
                  documentation, communication hygiene, and workflows so that when
                  a dispute becomes formal, the record is organized instead of
                  improvised.
                </li>
              </ul>
            </div>

            <div class="section-group">
              <div class="section-label">AI / OPS</div>
              <div class="section-subtitle">FOUNDER & TEAM SYSTEMS</div>
              <ul class="bullet-list">
                <li>
                  <strong>Founder ops compression</strong> — Wiring GPT, Claude,
                  and Gemini into outreach, content, and internal decision flows
                  so operators spend their time on leverage instead of inbox
                  warfare.
                </li>
                <li>
                  <strong>Diagnostics-first automation</strong> — Building
                  automation and scripting around bottlenecks and constraints
                  instead of dashboards that look smart and don’t move the
                  needle.
                </li>
              </ul>
            </div>

            <div class="section-group">
              <div class="section-label">PERFORMANCE</div>
              <div class="section-subtitle">BIOMECHANICS & LOAD PATHS</div>
              <ul class="bullet-list">
                <li>
                  <strong>Sprint-first diagnostics</strong> — Applying a
                  biomechanical and structural lens to human movement, then
                  mapping those principles into how operators design their
                  training, calendars, and contracts.
                </li>
                <li>
                  <strong>Footwear & equipment thinking</strong> — Designing
                  around force distribution and tensegrity instead of aesthetics,
                  so performance systems match the physics they pretend to
                  reference.
                </li>
              </ul>
            </div>
          </section>

          <section class="section">
            <h2 class="section-title">How I work</h2>
            <ul class="bullet-list">
              <li>
                <strong>Systems first, personalities second.</strong> I design
                around constraints, evidence, and incentives so the structure
                holds even when people get emotional.
              </li>
              <li>
                <strong>Legally in-bounds.</strong> I do not provide legal advice
                or act as counsel. I work alongside licensed attorneys and
                leadership teams as a strategist, operator, and builder of
                systems.
              </li>
              <li>
                <strong>Document before narrative.</strong> The story only counts
                if the paper can carry it. I optimize for what survives discovery
                and internal review, not what goes viral.
              </li>
            </ul>
          </section>

          <section class="section">
            <h2 class="section-title">Background</h2>
            <ul class="bullet-list">
              <li>BS Civil Engineering (FE passed 2012).</li>
              <li>
                Founder & 100% owner, Texas Movement International LLC — a
                multi-vertical systems company (performance, media, footwear, AI
                consulting, and economic development).
              </li>
              <li>
                Hands-on AI consulting, e-commerce operations, and media
                production for founders and small teams.
              </li>
              <li>
                Extensive experience drafting and coordinating complex motions and
                complaints as a pro se litigant working alongside attorneys.
              </li>
            </ul>
          </section>

          <section id="contact" class="section">
            <h2 class="section-title">Contact</h2>
            <p class="copy">
              I am a good fit when the stakes are real and the brief is clear.
              Send context, constraints, and what a “good outcome” would look
              like.
            </p>
            <a
              href="mailto:movementconsultant@gmail.com"
              class="contact-link"
            >
              movementconsultant@gmail.com
            </a>
            <p class="contact-note">
              Please do not send confidential legal information. I do not provide
              legal advice and no attorney-client relationship is formed through
              this site.
            </p>
          </section>
        </div>

        <!-- SIDEBAR -->
        <aside class="sidebar">
          <section class="sidebar-card">
            <h2 class="sidebar-title">Founder profile</h2>
            <p class="sidebar-name">Alexander V. Mathai</p>
            <p class="sidebar-role">
              Systems Engineer & Strategic Advisor<br />
              Founder, Texas Movement International LLC
            </p>
            <ul class="sidebar-list">
              <li>Civil engineering mindset</li>
              <li>AI systems & automation</li>
              <li>Pro se litigation experience</li>
              <li>Sprints & performance design</li>
            </ul>
          </section>

          <section class="sidebar-card">
            <h3 class="sidebar-subtitle">Core operating systems</h3>
            <ul class="sidebar-list">
              <li>
                <strong>Advisory & dispute systems</strong> — Frameworks for
                mapping multi-front problems into briefs, timelines, and decision
                docs that travel well between operators and counsel.
              </li>
              <li>
                <strong>Media & signal engine</strong> — Workflows that turn one
                deep session into LinkedIn scripts, long-form talks, and shorts
                without burning the operator out.
              </li>
              <li>
                <strong>Performance diagnostics</strong> — Structures that connect
                biomechanical efficiency with how people schedule work, training,
                and recovery under load.
              </li>
            </ul>
          </section>

          <section class="sidebar-card sidebar-meta">
            <p class="meta-line">
              Based near Chicago · Operating nationally.
            </p>
            <p class="meta-links">
              <a href="https://texasmovement.com/" target="_blank" rel="noreferrer">
                TexasMovement.com
              </a>
              ·
              <a
                href="https://consulting.texasmovement.com/"
                target="_blank"
                rel="noreferrer"
              >
                TMI Consulting
              </a>
              ·
              <a
                href="https://www.linkedin.com/in/alexandermathai"
                target="_blank"
                rel="noreferrer"
              >
                LinkedIn
              </a>
            </p>
          </section>
        </aside>
      </section>

      <section id="ecosystem" class="ecosystem">
        <div class="ecosystem-header">
          <h2 class="section-title">Texas Movement International ecosystem</h2>
          <p class="ecosystem-subtitle">
            The company is intentionally boring and structured. It exists so the
            builds are stable even when the operating conditions are not.
          </p>
        </div>

        <div class="ecosystem-grid">
          <article class="ecosystem-card">
            <div class="ecosystem-label">TMI CONSULTING</div>
            <h3 class="ecosystem-title">AI systems & operational builds.</h3>
            <p class="ecosystem-body">
              AI project consulting and organizational systems for founders and
              institutions that need process, not hype — diagnostics first,
              automation second.
            </p>
            <a
              href="https://consulting.texasmovement.com/"
              class="ecosystem-link"
              target="_blank"
              rel="noreferrer"
            >
              Consulting.TexasMovement.com →
            </a>
          </article>

          <article class="ecosystem-card">
            <div class="ecosystem-label">TM PERFORMANCE / HERO</div>
            <h3 class="ecosystem-title">Biomechanics & footwear systems.</h3>
            <p class="ecosystem-body">
              Footwear and training systems built from first principles for
              athletes and operators who care more about force distribution than
              trends.
            </p>
            <div class="ecosystem-links-row">
              <a
                href="https://hero.texasmovement.com/"
                target="_blank"
                rel="noreferrer"
              >
                HERO.TexasMovement.com →
              </a>
            </div>
          </article>

          <article class="ecosystem-card">
            <div class="ecosystem-label">TEXAS MOVEMENT MEDIA</div>
            <h3 class="ecosystem-title">Content as infrastructure.</h3>
            <p class="ecosystem-body">
              Pro talks and founder stories designed as durable signal — media
              built to support cases, careers, and cities over time.
            </p>
            <div class="ecosystem-links-row">
              <a
                href="https://www.youtube.com/@TexasMovementMedia"
                target="_blank"
                rel="noreferrer"
              >
                YouTube
              </a>
              <span class="ecosystem-dot">·</span>
              <a
                href="https://media.texasmovement.com/"
                target="_blank"
                rel="noreferrer"
              >
                Media.TexasMovement.com →
              </a>
            </div>
          </article>

          <article class="ecosystem-card">
            <div class="ecosystem-label">FOUNDER SIGNAL</div>
            <h3 class="ecosystem-title">Alexander V. Mathai</h3>
            <p class="ecosystem-body">
              Founder’s perspective on systems, performance, and operating inside
              a multi-vertical build — technical, legal-adjacent, and
              biomechanics-first commentary.
            </p>
            <div class="ecosystem-links-row">
              <a
                href="https://www.tiktok.com/@alexandervmathai"
                target="_blank"
                rel="noreferrer"
              >
                TikTok — @alexandervmathai
              </a>
              <span class="ecosystem-dot">·</span>
              <a
                href="https://www.linkedin.com/in/alexandermathai"
                target="_blank"
                rel="noreferrer"
              >
                LinkedIn
              </a>
            </div>
          </article>
        </div>
      </section>

      <footer class="footer">
        <div class="footer-dot">●</div>
        <p class="footer-note">
          Under active iteration — the systems get simpler as the stakes get
          higher.
        </p>
        <p class="footer-meta">
          © 2026 Alexander V. Mathai · Texas Movement International LLC
        </p>
      </footer>
    </main>
  </body>

  <style>
    :global(body) {
      margin: 0;
      min-height: 100vh;
      background: #020617;
      color: #e5e7eb;
      font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont,
        "Segoe UI", sans-serif;
    }

    .page {
      max-width: 1120px;
      margin: 0 auto;
      padding: 2.5rem 1.5rem 3.5rem;
      line-height: 1.7;
    }

    .site-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid rgba(148, 163, 184, 0.3);
      margin-bottom: 2.5rem;
    }

    .site-header-left {
      display: flex;
      align-items: center;
      gap: 0.9rem;
    }

    .site-mark {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      border-radius: 999px;
      border: 1px solid rgba(148, 163, 184, 0.7);
      font-size: 0.75rem;
      letter-spacing: 0.08em;
      color: #e5e7eb;
    }

    .site-title-block {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }

    .site-name {
      font-size: 0.95rem;
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #f9fafb;
    }

    .site-company {
      font-size: 0.85rem;
      color: #9ca3af;
    }

    .site-nav {
      display: flex;
      gap: 1.5rem;
      font-size: 0.9rem;
    }

    .site-nav a {
      color: #9ca3af;
      text-decoration: none;
    }

    .site-nav a:hover {
      color: #f9fafb;
    }

    .layout {
      display: grid;
      grid-template-columns: minmax(0, 2.1fr) minmax(0, 1.2fr);
      gap: 2.5rem;
      margin-top: 2.5rem;
    }

    .layout-main {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
    }

    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1.45fr) minmax(0, 1fr);
      gap: 2rem;
      align-items: start;
    }

    .eyebrow {
      font-size: 0.8rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #60a5fa;
      margin-bottom: 0.9rem;
    }

    .hero-title {
      font-size: 2.4rem;
      line-height: 1.15;
      letter-spacing: -0.03em;
      margin: 0 0 1.2rem;
      color: #f9fafb;
    }

    .hero-accent {
      color: #38bdf8;
    }

    .hero-body {
      font-size: 0.98rem;
      color: #d1d5db;
      margin: 0 0 0.9rem;
    }

    .hero-body-secondary {
      color: #9ca3af;
    }

    .hero-cta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.9rem;
      margin-top: 0.8rem;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.55rem 1.1rem;
      border-radius: 999px;
      font-size: 0.9rem;
      font-weight: 500;
      text-decoration: none;
      border: 1px solid transparent;
      cursor: pointer;
      transition: background 0.16s ease, color 0.16s ease,
        border-color 0.16s ease, transform 0.12s ease;
    }

    .button.primary {
      background: #38bdf8;
      color: #020617;
    }

    .button.primary:hover {
      background: #0ea5e9;
      transform: translateY(-1px);
    }

    .button.secondary {
      background: transparent;
      border-color: rgba(148, 163, 184, 0.7);
      color: #e5e7eb;
    }

    .button.secondary:hover {
      border-color: #e5e7eb;
      background: rgba(15, 23, 42, 0.9);
    }

    .hero-aside {
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
    }

    .portrait-wrap {
      border-radius: 0.75rem;
      overflow: hidden;
      border: 1px solid rgba(148, 163, 184, 0.4);
      background: radial-gradient(circle at top, #1e293b, #020617);
    }

    .portrait {
      display: block;
      width: 100%;
      height: auto;
      object-fit: cover;
    }

    .hero-tagline {
      font-size: 0.9rem;
      color: #9ca3af;
      margin: 0;
    }

    .metrics {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.2rem;
      padding: 1.2rem 1.1rem;
      border-radius: 0.9rem;
      border: 1px solid rgba(148, 163, 184, 0.4);
      background: radial-gradient(circle at top left, #020617, #020617),
        linear-gradient(
          135deg,
          rgba(37, 99, 235, 0.16),
          rgba(8, 47, 73, 0.45)
        );
    }

    .metrics-footnote {
      font-size: 0.75rem;
      color: #9ca3af;
      margin: 0.4rem 0 0;
    }

    .metric {
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
    }

    .metric-label {
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #9ca3af;
    }

    .metric-value {
      font-size: 1.2rem;
      font-weight: 600;
      color: #f9fafb;
    }

    .section {
      padding-top: 0.5rem;
      border-top: 1px solid rgba(148, 163, 184, 0.25);
    }

    .section + .section {
      margin-top: 1.8rem;
    }

    .section-title {
      font-size: 1.05rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #9ca3af;
      margin: 0 0 1rem;
    }

    .section-group {
      margin-bottom: 1.4rem;
    }

    .section-label {
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #60a5fa;
      margin-bottom: 0.15rem;
    }

    .section-subtitle {
      font-size: 0.9rem;
      font-weight: 500;
      color: #e5e7eb;
      margin-bottom: 0.45rem;
    }

    .bullet-list {
      list-style: disc;
      padding-left: 1.2rem;
      margin: 0.2rem 0 0;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      color: #d1d5db;
      font-size: 0.92rem;
    }

    .copy {
      margin: 0 0 0.5rem;
      color: #d1d5db;
      font-size: 0.95rem;
    }

    .contact-link {
      font-size: 0.95rem;
      color: #38bdf8;
      text-decoration: none;
    }

    .contact-link:hover {
      text-decoration: underline;
    }

    .contact-note {
      margin: 0.5rem 0 0;
      font-size: 0.8rem;
      color: #9ca3af;
      max-width: 32rem;
    }

    .sidebar {
      display: flex;
      flex-direction: column;
      gap: 1.6rem;
    }

    .sidebar-card {
      padding: 1.1rem 1.1rem 1.05rem;
      border-radius: 0.9rem;
      border: 1px solid rgba(148, 163, 184, 0.4);
      background: radial-gradient(circle at top left, #020617, #020617),
        linear-gradient(
          135deg,
          rgba(15, 23, 42, 0.9),
          rgba(15, 23, 42, 0.98)
        );
    }

    .sidebar-title {
      font-size: 0.95rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #9ca3af;
      margin: 0 0 0.6rem;
    }

    .sidebar-name {
      font-size: 1rem;
      font-weight: 600;
      color: #f9fafb;
      margin: 0 0 0.25rem;
    }

    .sidebar-role {
      font-size: 0.9rem;
      color: #d1d5db;
      margin: 0 0 0.7rem;
    }

    .sidebar-subtitle {
      font-size: 0.9rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #9ca3af;
      margin: 0 0 0.6rem;
    }

    .sidebar-list {
      list-style: disc;
      padding-left: 1.1rem;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
      font-size: 0.9rem;
      color: #d1d5db;
    }

    .sidebar-meta {
      font-size: 0.88rem;
      color: #9ca3af;
    }

    .meta-line {
      margin: 0 0 0.4rem;
    }

    .meta-links {
      margin: 0;
    }

    .meta-links a {
      color: #e5e7eb;
      text-decoration: none;
    }

    .meta-links a:hover {
      text-decoration: underline;
    }

    .ecosystem {
      margin-top: 3rem;
      padding-top: 2.2rem;
      border-top: 1px solid rgba(148, 163, 184, 0.3);
    }

    .ecosystem-header {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      margin-bottom: 1.7rem;
    }

    .ecosystem-subtitle {
      font-size: 0.95rem;
      color: #d1d5db;
      margin: 0;
      max-width: 32rem;
    }

    .ecosystem-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.35rem;
    }

    .ecosystem-card {
      padding: 1.1rem 1rem 1rem;
      border-radius: 0.9rem;
      border: 1px solid rgba(148, 163, 184, 0.35);
      background: radial-gradient(circle at top, #020617, #020617),
        linear-gradient(
          145deg,
          rgba(15, 23, 42, 0.9),
          rgba(15, 23, 42, 0.98)
        );
    }

    .ecosystem-label {
      font-size: 0.68rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #60a5fa;
