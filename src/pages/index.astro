---
import { SEO } from 'astro-seo';

// No astro:assets imports; hero and avatar come from public/

// Set `site: 'https://alexandermathai.com'` in astro.config.mjs
const siteUrl = (Astro.site?.href ?? 'https://alexandermathai.com/').replace(/\/$/, '');
const canonical = `${siteUrl}/`;

const title = 'Alexander Mathai — Founder, Texas Movement International';
const description =
  'Alexander Mathai operates Texas Movement International, a systems company for people who move. This is the founder and authority layer: keynotes, operating record, and routes into the ecosystem.';

const ogImage = `${siteUrl}/og-alexandermathai.png`;
const ogImageAlt = 'Alexander Mathai, Founder of Texas Movement International';
const twitterHandle = '@alexanderofnazareth';

const hubUrl = 'https://texasmovement.com';
const founderLinkUrl = 'https://founderlink.texasmovement.com';
const linkedinUrl = 'https://www.linkedin.com/in/alexandermathai';
const instagramUrl = 'https://www.instagram.com/alexanderofnazareth/';

// TODO: one-line swap to a branded mailbox (e.g. lex@alexandermathai.com) when live
const email = 'movementconsultant@gmail.com';
const keynoteMailto = `mailto:${email}?subject=${encodeURIComponent('Keynote Inquiry — [Event / City / Date]')}`;
const briefMailto = `mailto:${email}?subject=${encodeURIComponent('Project Brief — [Lane / Stakes / Deadline]')}`;

// Single source of truth for FAQ markup + FAQPage schema
const faqs = [
  {
    q: 'What is this page?',
    a: 'The founder and authority layer of Texas Movement International. It explains how I work, how the ecosystem is structured, and how to route serious work.',
  },
  {
    q: 'How do I work with you directly?',
    a: 'Most serious work routes through Texas Movement lanes, especially Consulting and FounderLink. Keynotes and select collaborations start with a brief sent via email.',
  },
  {
    q: 'Is this a personal brand site?',
    a: 'No. It is an operating record and authority layer. It exists to connect real work to the right lanes, not to collect attention without a system behind it.',
  },
  {
    q: 'Where should I follow ongoing thinking?',
    a: 'LinkedIn and Texas Movement Media carry most of the structured thinking in public. Instagram is where some of the texture and in-between live.',
  },
  {
    q: 'What kinds of work are not a fit?',
    a: 'Hype-first campaigns, vague no-context requests, and anything looking for a quick win with no stake or system behind it.',
  },
  {
    q: 'How does this connect to Texas Movement International?',
    a: 'I am the founder and operator behind Texas Movement International and its lanes. This page consolidates that identity so systems, AI, and people connect to one founder, not a scattered graph.',
  },
];

const personId = `${siteUrl}/#person`;
const orgId = 'https://texasmovement.com/#org';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': personId,
      name: 'Alexander Mathai',
      url: canonical,
      image: ogImage,
      jobTitle: 'Founder & President, Texas Movement International',
      description:
        'Founder of Texas Movement International, operating systems for performance, media, consulting, distribution, health, reparations, and public layers.',
      email: `mailto:${email}`,
      sameAs: [linkedinUrl, instagramUrl, hubUrl],
      worksFor: { '@id': orgId },
      knowsAbout: [
        'Systems design for founders',
        'AI and operations',
        'Performance and recovery',
        'Long-horizon economic leverage',
      ],
    },
    {
      '@type': 'Organization',
      '@id': orgId,
      name: 'Texas Movement International LLC',
      url: hubUrl,
      founder: { '@id': personId },
      contactPoint: [
        {
          '@type': 'ContactPoint',
          contactType: 'business inquiries',
          email,
          url: founderLinkUrl,
        },
      ],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      url: canonical,
      name: 'Alexander Mathai',
      inLanguage: 'en',
      publisher: { '@id': personId },
    },
    {
      '@type': 'WebPage',
      '@id': `${siteUrl}/#webpage`,
      url: canonical,
      name: title,
      description,
      isPartOf: { '@id': `${siteUrl}/#website` },
      about: { '@id': personId },
      primaryImageOfPage: ogImage,
    },
    {
      '@type': 'FAQPage',
      '@id': `${siteUrl}/#faq`,
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <SEO
      title={title}
      description={description}
      canonical={canonical}
      openGraph={{
        basic: {
          type: 'website',
          title,
          image: ogImage,
          url: canonical,
        },
        optional: {
          description,
          siteName: 'Alexander Mathai',
          locale: 'en_US',
        },
        image: {
          width: 1200,
          height: 630,
          alt: ogImageAlt,
          type: 'image/png',
        },
      }}
      twitter={{
        card: 'summary_large_image',
        site: twitterHandle,
        creator: twitterHandle,
        title,
        description,
        image: ogImage,
        imageAlt: ogImageAlt,
      }}
    />

    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#15181E" />

    

    {/* Production: self-host via @fontsource to cut third-party requests */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&family=Space+Grotesk:wght@500;600&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <style>
      /* Critical inline styles — lift to src/styles/index.css if the site grows */
      :root {
        --paper: #e7e8e2;
        --panel: #ddded7;
        --hero: #e9e0d5;
        --hero-soft: #f3ebe2;
        --hero-ink: #15181e;
        --hero-border: #b88d68;
        --ink: #15181e;
        --ink-soft: #454a54;
        --line: #c4c6bd;
        --line-strong: #a6a99f;
        --graphite: #111217;
        --white: #f4f5f0;
        --compression: #274a78;
        --tension: #bd3b22;
        --accent: #1f2937; /* CTA color */
        --wrap: 1080px;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
        -webkit-text-size-adjust: 100%;
      }

      body {
        background: var(--paper);
        color: var(--ink);
        font-family: 'IBM Plex Sans', system-ui, sans-serif;
        font-size: 16.5px;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      a:focus-visible,
      button:focus-visible {
        outline: 2px solid var(--compression);
        outline-offset: 3px;
        border-radius: 2px;
      }

      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        z-index: 100;
        background: var(--accent);
        color: var(--white);
        padding: 10px 16px;
        border-radius: 0 0 10px 0;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.78rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .skip-link:focus {
        left: 0;
      }

      .wrap {
        max-width: var(--wrap);
        margin: 0 auto;
        padding: 0 20px;
      }

      header {
        border-bottom: 1px solid var(--line);
        background: rgba(231, 232, 226, 0.96);
        backdrop-filter: blur(8px);
        position: sticky;
        top: 0;
        z-index: 40;
      }

      .topbar {
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
      }

      .brand {
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 600;
        font-size: 1rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
      }

      .brand-mark img {
        height: 28px;
        width: 28px;
        border-radius: 999px;
        display: block;
      }

      .site-nav {
        display: flex;
        gap: 18px;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.72rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--ink-soft);
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .site-nav a:hover {
        color: var(--ink);
      }

      .nav-toggle {
        display: none;
        align-items: center;
        gap: 8px;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.72rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--ink);
        background: transparent;
        border: 1px solid var(--line-strong);
        border-radius: 999px;
        padding: 8px 14px;
        cursor: pointer;
      }

      main {
        padding-bottom: 72px;
      }

      .section {
        padding: 72px 0;
      }

      .section--tight {
        padding: 60px 0;
      }

      .section--panel {
        background: var(--panel);
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
      }

      .eyebrow {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.72rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--ink-soft);
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 18px;
      }

      .eyebrow::before {
        content: '';
        width: 32px;
        height: 1px;
        background: var(--tension);
        flex: none;
      }

      h1,
      h2,
      h3 {
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 600;
        line-height: 1.06;
        letter-spacing: -0.02em;
      }

      h1 {
        font-size: clamp(2.4rem, 4.2vw, 3.4rem);
        margin-bottom: 16px;
      }

      h2 {
        font-size: clamp(1.7rem, 3vw, 2.2rem);
        margin-bottom: 16px;
      }

      h3 {
        font-size: 1.1rem;
        margin-bottom: 6px;
      }

      p {
        color: var(--ink-soft);
        max-width: 46em;
      }

      p strong {
        color: var(--ink);
        font-weight: 600;
      }

      .hero {
        border-bottom: 1px solid var(--line);
        background: linear-gradient(130deg, var(--hero), var(--hero-soft));
      }

      .hero-inner {
        display: grid;
        grid-template-columns: minmax(0, 1.3fr) minmax(0, 0.9fr);
        gap: 40px;
        align-items: center;
      }

      .hero-tagline {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.76rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--ink-soft);
        margin-bottom: 10px;
      }

      .hero-body {
        font-size: 1.02rem;
        margin-bottom: 16px;
      }

      .hero-note {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--ink-soft);
        margin-top: 10px;
      }

      .hero-ctas {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 18px;
      }

      .btn {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.78rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        padding: 11px 18px;
        border-radius: 999px;
        border: 1px solid var(--accent);
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--accent);
        color: var(--white);
        transition: 0.18s ease;
      }

      .btn:hover {
        background: transparent;
        color: var(--accent);
      }

      .btn--ghost {
        background: transparent;
        color: var(--accent);
      }

      .btn--ghost:hover {
        background: var(--accent);
        color: var(--white);
      }

      .btn .arrow {
        transition: transform 0.16s ease;
      }

      .btn:hover .arrow {
        transform: translateX(3px);
      }

      .hero-photo {
        position: relative;
        border-radius: 18px;
        overflow: hidden;
        border: 1px solid var(--line-strong);
        background-color: #d8dad1;
        background-size: cover;
        background-position: center;
      }

      .hero-photo img {
        display: block;
        width: 100%;
        height: auto;
      }

      .hero-photo-caption {
        position: absolute;
        bottom: 10px;
        right: 14px;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.68rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--ink-soft);
        background: rgba(231, 232, 226, 0.86);
        padding: 4px 8px;
        border-radius: 999px;
        border: 1px solid var(--line);
      }

      .grid-2 {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
        gap: 40px;
        align-items: flex-start;
      }

      .cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 18px;
        margin-top: 18px;
      }

      .card {
        border-radius: 14px;
        border: 1px solid var(--line-strong);
        background: var(--paper);
        padding: 16px 16px 14px;
        display: flex;
        flex-direction: column;
        gap: 6px;
      }

      .card-label {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--ink-soft);
      }

      .card-title {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.02rem;
        font-weight: 600;
        line-height: 1.25;
        margin-bottom: 0;
      }

      .card-body {
        font-size: 0.9rem;
        color: var(--ink-soft);
      }

      .cta-link {
        margin-top: 6px;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.78rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .cta-link a {
        border-bottom: 1px solid transparent;
      }

      .cta-link a:hover {
        border-bottom-color: var(--accent);
      }

      .fineprint {
        margin-top: 12px;
        font-size: 0.9rem;
        color: var(--ink-soft);
      }

      .social-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 16px;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.78rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .social-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 12px;
        border-radius: 999px;
        border: 1px solid var(--line-strong);
        background: var(--paper);
        color: var(--ink-soft);
      }

      .social-pill:hover {
        border-color: var(--accent);
        color: var(--accent);
      }

      .faq-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 18px;
        margin-top: 20px;
      }

      .faq-item {
        border-radius: 14px;
        border: 1px solid var(--line-strong);
        padding: 16px 16px 14px;
        background: var(--paper);
        font-size: 0.9rem;
        color: var(--ink-soft);
      }

      footer {
        padding: 24px 0 30px;
        background: var(--graphite);
        color: #9aa0ab;
        border-top: 1px solid #2c313b;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.06em;
      }

      .footer-inner {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 10px;
        align-items: center;
      }

      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 8px 14px;
      }

      .footer-links a:hover {
        color: #e5e7eb;
      }

      @media (max-width: 900px) {
        .hero-inner {
          grid-template-columns: 1fr;
        }

        .grid-2 {
          grid-template-columns: 1fr;
        }

        .wrap {
          padding: 0 18px;
        }

        .nav-toggle {
          display: inline-flex;
        }

        .site-nav {
          display: none;
          position: absolute;
          top: 64px;
          left: 0;
          right: 0;
          flex-direction: column;
          align-items: flex-start;
          gap: 14px;
          padding: 18px 20px 22px;
          background: rgba(231, 232, 226, 0.98);
          border-bottom: 1px solid var(--line);
          backdrop-filter: blur(8px);
        }

        .site-nav[data-state='open'] {
          display: flex;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }

        .btn,
        .btn .arrow {
          transition: none;
        }
      }
    </style>
  </head>

  <body id="top">
    <a class="skip-link" href="#main-content">Skip to main content</a>

    <header>
      <div class="wrap">
        <div class="topbar">
          <a href="#top" class="brand" aria-label="Alexander Mathai — back to top">
                        <span class="brand-mark" aria-hidden="true">
              <img
                src="/AVM-Blue-turtleneck-standing-arm-cross.jpg"
                width="28"
                height="28"
                alt=""
                loading="eager"
                decoding="async"
              />
            </span>
            <span>ALEXANDER MATHAI</span>
          </a>

          <button
            class="nav-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="site-nav"
          >
            <span class="nav-toggle-label">Menu</span>
          </button>

          <nav id="site-nav" class="site-nav" data-state="closed" aria-label="Primary">
            <a href="#overview">Overview</a>
            <a href="#keynote">Keynotes</a>
            <a href="#systems">Systems work</a>
            <a href="#ecosystem">Ecosystem</a>
            <a href="#faq">FAQ</a>
            <a href="#contact">Contact</a>
          </nav>
        </div>
      </div>
    </header>

    <main id="main-content" tabindex="-1">
      <!-- Hero / authority layer -->
      <section id="overview" class="section hero">
        <div class="wrap hero-inner">
          <div>
            <p class="hero-tagline">
              FOUNDER · SYSTEMS · TEXAS MOVEMENT INTERNATIONAL.
            </p>
            <h1>The founder and authority layer of Texas Movement.</h1>
            <p class="hero-body">
              I build <strong>systems</strong> for people and institutions who have
              real stakes: athletes, founders, cities, and families. Texas Movement
              International is the company. This page is the personal authority
              layer that explains how I think, how I work, and where to route
              serious work.
            </p>
            <p class="hero-body">
              It exists so collaborators, clients, and teams can see the operating
              record in one place—then enter the right <strong>lane</strong>:
              Consulting for systems, Performance and Health for the physical
              layer, Media for signal, Distribution for rights and catalog,
              FounderLink for intake, Social for events, and Reparations for
              structural analysis.
            </p>
            <div class="hero-ctas">
              <a
                class="btn"
                href={founderLinkUrl}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Start intake via FounderLink (opens in a new tab)"
              >
                Start intake · FounderLink <span class="arrow" aria-hidden="true">→</span>
              </a>
              <a
                class="btn btn--ghost"
                href={hubUrl}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Explore the Texas Movement ecosystem hub (opens in a new tab)"
              >
                Explore the hub <span class="arrow" aria-hidden="true">→</span>
              </a>
            </div>
            <p class="cta-link">
              <a href="#keynote">Booking a stage? Keynotes ↓</a>
            </p>
            <p class="hero-note">
              ONE FOUNDER · ONE SYSTEM · SEVERAL LANES · BUILT FOR SERIOUS WORK
            </p>

            <div class="social-row">
              <a
                class="social-pill"
                href={linkedinUrl}
                target="_blank"
                rel="me noopener noreferrer"
                aria-label="Alexander Mathai on LinkedIn (opens in a new tab)"
              >
                <span>LinkedIn</span> <span aria-hidden="true">↗</span>
              </a>
              <a
                class="social-pill"
                href={instagramUrl}
                target="_blank"
                rel="me noopener noreferrer"
                aria-label="Alexander Mathai on Instagram (opens in a new tab)"
              >
                <span>Instagram</span> <span>@alexanderofnazareth</span>
              </a>
              <a
                class="social-pill"
                href={hubUrl}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="TexasMovement.com ecosystem hub (opens in a new tab)"
              >
                <span>TexasMovement.com</span> <span>ecosystem hub</span>
              </a>
            </div>
          </div>

                    <figure class="hero-photo" style="background-image:url('/AVM-Blue-turtleneck-standing-arm-cross.jpg')">
            <img
              src="/AVM-Blue-turtleneck-standing-arm-cross.jpg"
              alt="Alexander Mathai standing with arms crossed, wearing a blue turtleneck"
              loading="eager"
              decoding="async"
            />
            <figcaption class="hero-photo-caption">
              ALEXANDER MATHAI - PRESIDENT AND FOUNDER
            </figcaption>
          </figure>
        </div>
      </section>

      <!-- Keynote & live speaking -->
      <section id="keynote" class="section section--panel">
        <div class="wrap grid-2">
          <div>
            <div class="eyebrow">KEYNOTES & LIVE WORK</div>
            <h2>Systems, performance, AI, and economic leverage for serious rooms.</h2>
            <p>
              Keynote and live speaking are for conferences, offsites, and rooms
              where people are actually making <strong>decisions</strong>. Topics
              cover systems for founders, AI and operations, performance and
              recovery, and long-horizon economic leverage.
            </p>
            <p>
              Every keynote is scoped like consulting work: clear constraints,
              outcomes, and accountability. The point is not a talk that sounds
              good—for a day—but a session that changes how people see their
              operating <strong>system</strong>.
            </p>

            <p class="cta-link">
              <a href={keynoteMailto}>Email a keynote inquiry →</a>
            </p>
          </div>

          <aside aria-label="Keynote angles">
            <div class="cards-grid">
              <article class="card">
                <div class="card-label">Angle</div>
                <h3 class="card-title">Systems for founders.</h3>
                <p class="card-body">
                  How to turn messy problems into systems you can run—constraints,
                  sequencing, and the operating record that survives review.
                </p>
              </article>
              <article class="card">
                <div class="card-label">Angle</div>
                <h3 class="card-title">AI and operations.</h3>
                <p class="card-body">
                  How to use AI inside systems so it reduces friction instead of
                  creating new chaos. Workflows and decision paths, not hype.
                </p>
              </article>
